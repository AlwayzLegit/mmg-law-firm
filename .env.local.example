# ============================================================
# MMG Law Firm — environment template
# ============================================================
# Copy to `.env.local` for local dev, or paste each value into
# Vercel → Project → Settings → Environment Variables for prod.
# Empty values are tolerated in dev (with warnings); missing prod
# values throw at runtime — see src/lib/env.ts.
#
# DEPLOY.md walks through where to obtain every value.
# ============================================================

# ---- Site -----------------------------------------------------------------
# Canonical URL the site is served from. MUST match the deployed origin
# exactly (no trailing slash) — used for canonical tags, OG image URLs,
# and JSON-LD `url` fields.
# Local dev:   http://localhost:3000
# Production:  https://www.mmg-lawfirm.com
NEXT_PUBLIC_SITE_URL=https://www.mmg-lawfirm.com

# ---- Supabase --------------------------------------------------------------
# Get these from Supabase → Project → Settings → API.
#
# - URL is public — safe to expose.
# - ANON KEY is public — RLS protects all tables.
# - SERVICE ROLE KEY is SECRET — bypasses RLS. Only used server-side
#   (lead inserts, headshot uploads, admin invites). NEVER ship to client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Resend (transactional email) -----------------------------------------
# Get the API key from Resend → API Keys.
# RESEND_FROM_EMAIL must be an address on a domain you've verified in
# Resend → Domains. The domain's SPF / DKIM records are added to your DNS
# provider. Until verification is complete, sends will fail with 422.
#
# LEAD_NOTIFY_EMAIL is the inbox that receives "new lead" notifications.
RESEND_API_KEY=
RESEND_FROM_EMAIL=intake@mmg-lawfirm.com
LEAD_NOTIFY_EMAIL=mihran@mmg-lawfirm.com

# ---- Cloudflare Turnstile (anti-bot on the lead form) ---------------------
# Cloudflare → Turnstile → Add Site. Pick "Managed" challenge.
# Add hostnames: your prod domain + `localhost` for dev.
#
# - SITE KEY is public.
# - SECRET KEY is server-only — verifies the token in /api/leads.
# Without these, the lead form will reject every submission in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Twilio (SMS — OPTIONAL) ----------------------------------------------
# Leave empty until 10DLC brand registration is complete and the firm has a
# compliant A2P 10DLC campaign. The lead pipeline functions fine without
# SMS — it's stubbed out and silently no-ops when these are blank.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Google Analytics (OPTIONAL) ------------------------------------------
# GA4 Measurement ID, e.g. "G-XXXXXXXXXX". Empty disables analytics.
NEXT_PUBLIC_GA_ID=

# ---- ISR revalidation secret (OPTIONAL) -----------------------------------
# Random shared secret for the /api/revalidate endpoint. Used to manually
# kick a static page rebuild from outside the admin (e.g. a webhook).
# `openssl rand -hex 32` is a good way to generate one.
REVALIDATE_SECRET=
